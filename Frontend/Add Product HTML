<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Product - Salesforce</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <aside class="sidebar">
            <h2>SalesForce</h2>
            <ul>
                <li>Dashboard</li>
                <li>Customers</li>
                <li>Orders</li>
                <li class="active">Products</li>
                <li>Settings</li>
            </ul>
        </aside>

        <main class="main-content">
            <header>
                <h1>Create New Product</h1>
                <div class="form-actions">
                    <button class="btn-cancel">Cancel</button>
                    <button class="btn-save" id="saveBtn">Save Product</button>
                </div>
            </header>

            <section class="form-container">
                <form id="productForm">
                    <div class="form-grid">
                        <div class="form-section">
                            <h3>Basic Information</h3>
                            <div class="input-group">
                                <label>Product Name</label>
                                <input type="text" placeholder="e.g. MacBook Pro" required>
                            </div>
                            <div class="input-group">
                                <label>Category</label>
                                <select>
                                    <option>Electronics</option>
                                    <option>Software</option>
                                    <option>Hardware</option>
                                </select>
                            </div>
                            <div class="input-row">
                                <div class="input-group">
                                    <label>Price ($)</label>
                                    <input type="number" placeholder="0.00">
                                </div>
                                <div class="input-group">
                                    <label>Stock Quantity</label>
                                    <input type="number" placeholder="0">
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3>Description & Media</h3>
                            <div class="input-group">
                                <label>Description</label>
                                <textarea rows="5" placeholder="Enter product details..."></textarea>
                            </div>
                            <div class="input-group">
                                <label>Product Image</label>
                                <div class="upload-box">
                                    <span>Click to upload image</span>
                                    <input type="file" hidden id="fileInput">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </section>
        </main>
    </div>
    <script>
        // JS بسيط عشان لما يدوس Save يظهر رسالة نجاح
        document.getElementById('saveBtn').onclick = function() {
            alert('Product Created Successfully!');
            window.location.href = 'products.html'; // يرجعه لصفحة المنتجات
        };
    </script>
</body>
</html>
