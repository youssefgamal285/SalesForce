<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Salesforce Dashboard</title>
    <link rel="stylesheet" href="style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="container">
        <aside class="sidebar">
            <h2>SalesForce</h2>
            <ul>
                <li class="active">Dashboard</li>
                <li>Customers</li>
                <li>Orders</li>
                <li>Products</li>
                <li>Settings</li>
            </ul>
        </aside>

        <main class="main-content">
            <header>
                <h1>Overview</h1>
                <div class="user-info">Welcome, Admin</div>
            </header>

            <div class="stats-grid">
                <div class="card">
                    <h3>Total Sales</h3>
                    <p class="number">$24,500</p>
                    <span class="trend">+12% Since last month</span>
                </div>
                <div class="card">
                    <h3>Active Orders</h3>
                    <p class="number">156</p>
                    <span class="trend">5 Pending</span>
                </div>
                <div class="card">
                    <h3>New Customers</h3>
                    <p class="number">42</p>
                    <span class="trend">+5% this week</span>
                </div>
            </div>

            <div class="chart-container">
                <h3>Sales Performance</h3>
                <canvas id="salesChart"></canvas>
            </div>
        </main>
    </div>
    <script src="script.js"></script>
</body>
</html>
